{
  "name": "@letsrunit/cucumber",
  "version": "0.25.0",
  "description": "Cucumber CLI integration for letsrunit BDD step definitions",
  "keywords": [
    "testing",
    "bdd",
    "cucumber",
    "playwright",
    "letsrunit"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/letsrunit-hq/letsrunit.git",
    "directory": "packages/cucumber"
  },
  "bugs": "https://github.com/letsrunit-hq/letsrunit/issues",
  "homepage": "https://github.com/letsrunit-hq/letsrunit#readme",
  "type": "module",
  "main": "./src/index.ts",
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./store": {
        "types": "./dist/store.d.ts",
        "import": "./dist/store.js",
        "default": "./dist/store.js"
      },
      "./stream": {
        "types": "./dist/stream.d.ts",
        "import": "./dist/stream.js",
        "default": "./dist/stream.js"
      },
      "./progress": {
        "types": "./dist/progress.d.ts",
        "import": "./dist/progress.js",
        "default": "./dist/progress.js"
      },
      "./agent": {
        "types": "./dist/agent.d.ts",
        "import": "./dist/agent.js",
        "default": "./dist/agent.js"
      },
      "./config": {
        "types": "./dist/config.d.ts",
        "import": "./dist/config.js",
        "default": "./dist/config.js"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "../../node_modules/.bin/tsup"
  },
  "packageManager": "yarn@4.12.0",
  "dependencies": {
    "@cucumber/messages": "^31.0.0",
    "@letsrunit/bdd": "workspace:*",
    "@letsrunit/gherkin": "workspace:*",
    "@letsrunit/playwright": "workspace:*",
    "@letsrunit/store": "workspace:*",
    "@letsrunit/utils": "workspace:*",
    "uuid": "^14.0.1"
  },
  "peerDependencies": {
    "@cucumber/cucumber": "^12.0.0",
    "@playwright/test": "^1.61.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@playwright/test": "1.61.0"
  },
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./store": {
      "types": "./src/store.ts",
      "import": "./src/store.ts",
      "default": "./src/store.ts"
    },
    "./stream": {
      "types": "./src/stream.ts",
      "import": "./src/stream.ts",
      "default": "./src/stream.ts"
    },
    "./progress": {
      "types": "./src/progress.ts",
      "import": "./src/progress.ts",
      "default": "./src/progress.ts"
    },
    "./agent": {
      "types": "./src/agent.ts",
      "import": "./src/agent.ts",
      "default": "./src/agent.ts"
    },
    "./config": {
      "types": "./src/config.ts",
      "import": "./src/config.ts",
      "default": "./src/config.ts"
    }
  }
}
