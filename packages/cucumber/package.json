{
  "name": "@letsrunit/cucumber",
  "version": "0.1.0",
  "description": "Cucumber CLI integration for letsrunit BDD step definitions",
  "keywords": [
    "testing",
    "bdd",
    "cucumber",
    "playwright",
    "letsrunit"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/letsrunit-hq/letsrunit.git",
    "directory": "packages/cucumber"
  },
  "bugs": "https://github.com/letsrunit-hq/letsrunit/issues",
  "homepage": "https://github.com/letsrunit-hq/letsrunit#readme",
  "type": "module",
  "main": "./src/index.ts",
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./artifacts": {
        "types": "./dist/artifacts.d.ts",
        "import": "./dist/artifacts.js",
        "default": "./dist/artifacts.js"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "../../node_modules/.bin/tsup"
  },
  "packageManager": "yarn@4.10.3",
  "dependencies": {
    "@cucumber/messages": "^31.0.0",
    "@letsrunit/bdd": "workspace:*",
    "@letsrunit/gherkin": "workspace:*",
    "@letsrunit/playwright": "workspace:*",
    "@letsrunit/store": "workspace:*",
    "@playwright/test": "^1.57.0",
    "uuid": "^13.0.0"
  },
  "peerDependencies": {
    "@cucumber/cucumber": "^12.0.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0"
  },
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./artifacts": {
      "types": "./src/artifacts.ts",
      "import": "./src/artifacts.ts",
      "default": "./src/artifacts.ts"
    }
  }
}
